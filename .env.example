# --- Google Maps (필수: 지도/Static Maps/Directions/Places API 모두 동일 키) ---
# "오늘" 모드의 "근처 추천"은 Places API(legacy Nearby Search)를 씁니다 —
# Cloud Console에서 Places API도 사용 설정해 주세요. 미설정이면 그 기능만 비활성.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_javascript_api_key
# (선택) 서버 전용 Directions/Places 호출용. 미설정 시 위 NEXT_PUBLIC 키 재사용
# GOOGLE_MAPS_SERVER_KEY=

# --- Supabase (필수: 메모리 동기화/사진 업로드/일정 편집 저장) ---
# Settings → API 에서 복사
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_server_only_service_role_key
# (선택) 클라이언트에서도 URL이 필요한 경우 (현재는 안 씀)
# NEXT_PUBLIC_SUPABASE_URL=

# --- (선택) 항공편 실시간 상태 — AviationStack 무료 플랜 (월 100콜) ---
# https://aviationstack.com → API Access Key. 미설정 시 보관함에서 "항공 API 미설정"으로 표시
# AVIATIONSTACK_KEY=your_aviationstack_access_key

# --- 트립 식별자 ---
# 한 인스턴스로 여러 트립 분리 운영 시 변경. 기본값은 fukuoka-2026
TRIP_ID=osaka-2026

# --- (선택) 사진 버킷 이름. 기본값 osaka-photos ---
# SUPABASE_PHOTO_BUCKET=osaka-photos

# --- (선택) OpenAI — 번역 + 음성 인식(STT) ---
# 미설정 시 번역기 FAB은 보이지만 호출 시 503 응답.
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key
# (선택) 모델 오버라이드 — 기본값으로 충분합니다
# OPENAI_TRANSLATE_MODEL=gpt-5.4-mini
# OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
